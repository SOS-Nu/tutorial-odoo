<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. Định nghĩa Privilege (Mới trong Odoo 19) -->
    <record id="privilege_sale_management" model="res.groups.privilege">
        <name>BT Sale Management</name>
        <field name="category_id" ref="base.module_category_sales_sales"/>
    </record>

    <!-- 2. Định nghĩa Groups sử dụng privilege_id -->
    <record id="group_sale_management_user" model="res.groups">
        <name>BT Sale Management: User</name>
        <field name="privilege_id" ref="privilege_sale_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_sale_management_manager" model="res.groups">
        <name>BT Sale Management: Manager</name>
        <field name="privilege_id" ref="privilege_sale_management"/>
        <field name="implied_ids" eval="[(4, ref('group_sale_management_user'))]"/>
    </record>

    <!-- 3. Tự động gán quyền cho Admin -->
    <record id="base.user_admin" model="res.users">
        <field name="groups_id" eval="[(4, ref('bt_sale_management.group_sale_management_manager'))]"/>
    </record>
</odoo>
